{
  "name": "zhi-xue-ban",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder --win",
    "electron:start": "next build && electron ."
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "mammoth": "^1.12.0",
    "next": "16.2.9",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4"
  },
  "build": {
    "appId": "com.zhixueban.app",
    "productName": "智学伴",
    "directories": {
      "output": "release"
    },
    "files": [
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json",
      "main.js",
      "next.config.mjs"
    ],
    "win": {
      "target": "portable",
      "icon": "public/favicon.ico"
    },
    "npmRebuild": false,
    "electronVersion": "42.5.0",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  }
}
